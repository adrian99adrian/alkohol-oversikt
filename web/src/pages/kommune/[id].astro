---
import fs from "node:fs";
import path from "node:path";
import Base from "../../layouts/Base.astro";
import DayCard from "../../components/DayCard.astro";
import BeerSalesTable from "../../components/BeerSalesTable.astro";
import type { MunicipalityData } from "../../types";

export function getStaticPaths() {
  const dataDir = path.resolve(process.cwd(), "..", "data", "generated", "municipalities");

  if (!fs.existsSync(dataDir)) {
    return [];
  }

  const files = fs.readdirSync(dataDir).filter((f: string) => f.endsWith(".json"));

  return files.map((file: string) => {
    const raw = fs.readFileSync(path.join(dataDir, file), "utf-8");
    const data: MunicipalityData = JSON.parse(raw);
    return {
      params: { id: data.municipality.id },
      props: { data },
    };
  });
}

const { data } = Astro.props as { data: MunicipalityData };
const { municipality, days } = data;

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;

// Compare first day in data to the actual build date to detect stale data
const buildDate = new Date().toISOString().slice(0, 10); // YYYY-MM-DD
const dataIsFresh = days.length > 0 && days[0].date === buildDate;

const today = days[0] ?? null;
const tomorrow = days[1] ?? null;

function formatCardLabel(dateStr: string): string {
  const [, month, day] = dateStr.split("-");
  return `${day}.${month}`;
}

// First 14 days for the table
const tableDays = days.slice(0, 14);

// Next deviation: first day (inclusive of today) where is_deviation is true
const nextDeviation = days.find((d) => d.is_deviation) ?? null;

function formatDeviationDate(dateStr: string): string {
  const [, month, day] = dateStr.split("-");
  return `${day}.${month}`;
}
---

<Base title={`${municipality.name} — Alkohol-oversikt`}>
  <div>
    <a href={basePath} class="mb-4 inline-block text-sm text-slate-400 hover:text-slate-200">
      ← Tilbake
    </a>

    <h1 class="mb-6 text-2xl font-bold text-white">{municipality.name}</h1>

    <!-- Today and Tomorrow cards -->
    <div class="mb-6 grid gap-4 sm:grid-cols-2">
      <DayCard label={dataIsFresh ? "I dag" : today ? formatCardLabel(today.date) : "—"} day={today} />
      <DayCard label={dataIsFresh ? "I morgen" : tomorrow ? formatCardLabel(tomorrow.date) : "—"} day={tomorrow} />
    </div>

    <!-- Next deviation alert -->
    {nextDeviation && (
      <div class="mb-6 rounded-lg border border-amber-700 bg-amber-900/30 p-3">
        <p class="text-sm text-amber-200">
          <span class="font-semibold">Neste avvik:</span>{" "}
          {nextDeviation.weekday.charAt(0).toUpperCase() + nextDeviation.weekday.slice(1)}{" "}
          {formatDeviationDate(nextDeviation.date)} —{" "}
          {nextDeviation.comment ?? nextDeviation.day_type_label}
        </p>
      </div>
    )}

    <!-- 14-day table -->
    <section>
      <h2 class="mb-4 text-lg font-semibold text-slate-200">Neste 14 dager</h2>
      {tableDays.length > 0 ? (
        <BeerSalesTable days={tableDays} />
      ) : (
        <p class="text-slate-400">Ingen data tilgjengelig</p>
      )}
    </section>
  </div>
</Base>
