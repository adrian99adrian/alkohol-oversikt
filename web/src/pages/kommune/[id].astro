---
import fs from "node:fs";
import path from "node:path";
import Base from "../../layouts/Base.astro";
import DayCard from "../../components/DayCard.astro";
import DayTypeLegend from "../../components/DayTypeLegend.astro";
import BeerSalesTable from "../../components/BeerSalesTable.astro";
import VinmonopoletList from "../../components/VinmonopoletList.astro";
import type { MunicipalityData } from "../../types";
import { formatDateShort, formatDateLong } from "../../lib/dateFormat";
import {
  normalizeBasePath,
  isDataFresh,
  findNextDeviation,
  capitalizeFirst,
  isVinmonopoletStale,
  VINMONOPOLET_STALE_THRESHOLD_DAYS,
} from "../../lib/dataUtils";
import { hasLateBeerOpening } from "../../lib/beerOpening";

export function getStaticPaths() {
  const dataDir = path.resolve(process.cwd(), "..", "data", "generated", "municipalities");

  if (!fs.existsSync(dataDir)) {
    return [];
  }

  const files = fs.readdirSync(dataDir).filter((f: string) => f.endsWith(".json"));

  return files.map((file: string) => {
    const raw = fs.readFileSync(path.join(dataDir, file), "utf-8");
    const data: MunicipalityData = JSON.parse(raw);
    return {
      params: { id: data.municipality.id },
      props: { data },
    };
  });
}

const { data } = Astro.props as { data: MunicipalityData };
const { municipality, days, vinmonopolet_stores, vinmonopolet_day_summary } = data;

const basePath = normalizeBasePath(import.meta.env.BASE_URL);

// Compare first day in data to the actual build date to detect stale data
const buildDate = new Date().toISOString().slice(0, 10); // YYYY-MM-DD
const dataIsFresh = isDataFresh(days, buildDate);

const today = days[0] ?? null;
const tomorrow = days[1] ?? null;

// First 14 days for the table
const tableDays = days.slice(0, 14);

// Show a note when this municipality's beer sales open later than the national
// default (08:00) on any upcoming sales day.
const showLateOpeningNote = hasLateBeerOpening(tableDays);

// Next deviation: first day within the 14-day window where is_deviation is true
const nextDeviation = findNextDeviation(tableDays);

// Vinmonopolet day summary for the table (first 14 days)
const daySummary = vinmonopolet_day_summary ?? [];

// Vinmonopolet staleness check (build-time snapshot).
// Only show the warning when this municipality actually has stores — otherwise
// the Vinmonopolet section is hidden and the warning would be misleading.
const vinmonopoletFetchedAt = data.vinmonopolet_fetched_at;
const isVinmonopoletWarning =
  vinmonopolet_stores.length > 0 &&
  isVinmonopoletStale(vinmonopoletFetchedAt, VINMONOPOLET_STALE_THRESHOLD_DAYS);
// Slice YYYY-MM-DD out of the ISO timestamp to keep the producer's local-day
// (fetch_vinmonopolet writes Europe/Oslo local time), avoiding UTC drift when
// formatting for display.
const fetchedAtFormatted = vinmonopoletFetchedAt
  ? formatDateLong(vinmonopoletFetchedAt.slice(0, 10))
  : null;
---

<Base
  title={`${municipality.name} — Alkohol-oversikt`}
  description={`Se når ølsalget stenger og Vinmonopolet er åpent i ${municipality.name}.`}
  canonicalPath={`/kommune/${municipality.id}/`}
  buildDate={buildDate}
  lastVerified={municipality.last_verified ?? undefined}
>
  <div>
    <a href={basePath} class="mb-4 inline-block text-sm text-slate-400 hover:text-slate-200">
      ← Tilbake
    </a>

    <h1 class="mb-4 text-2xl font-bold text-white">{municipality.name}</h1>

    <div class="mb-6">
      <DayTypeLegend />
    </div>

    <!-- Unverified beer-sales rules warning (highest-priority trust signal) -->
    {!municipality.verified && (
      <div class="mb-6 rounded-lg border border-amber-700 bg-amber-900/30 p-3">
        <p class="text-sm text-amber-200">
          <span class="font-semibold">NB:</span> Ølsalgsreglene for {municipality.name} er ikke verifisert. Tidene kan avvike fra lokale regler.
        </p>
      </div>
    )}

    <!-- Vinmonopolet staleness warning -->
    {isVinmonopoletWarning && (
      <div class="mb-6 rounded-lg border border-amber-700 bg-amber-900/30 p-3">
        <p class="text-sm text-amber-200">
          ⚠️ Problemer med å hente Vinmonopolet-data, åpningstidene kan være utdaterte ⚠️
          {fetchedAtFormatted && <span> (sist hentet {fetchedAtFormatted})</span>}
        </p>
      </div>
    )}

    <!-- Late beer opening note -->
    {showLateOpeningNote && (
      <div class="mb-6 rounded-lg border border-amber-700 bg-amber-900/30 p-3">
        <p class="text-sm text-amber-200">
          <span class="font-semibold">NB:</span> Ølsalget åpner senere enn vanlig i {municipality.name}.
        </p>
      </div>
    )}

    <!-- Today and Tomorrow cards -->
    <div class="mb-6 grid gap-4 sm:grid-cols-2">
      <DayCard
        label={dataIsFresh ? "I dag" : today ? formatDateShort(today.date) : "—"}
        day={today}
        vinmonopoletSummary={today?.vinmonopolet_summary}
      />
      <DayCard
        label={dataIsFresh ? "I morgen" : tomorrow ? formatDateShort(tomorrow.date) : "—"}
        day={tomorrow}
        vinmonopoletSummary={tomorrow?.vinmonopolet_summary}
      />
    </div>

    <!-- Next deviation alert -->
    {nextDeviation && (
      <div class="mb-6 rounded-lg border border-amber-700 bg-amber-900/30 p-3">
        <p class="text-sm text-amber-200">
          <span class="font-semibold">Neste avvik:</span>{" "}
          {capitalizeFirst(nextDeviation.weekday)}{" "}
          {formatDateShort(nextDeviation.date)} —{" "}
          {nextDeviation.comment ?? nextDeviation.day_type_label}
        </p>
      </div>
    )}

    <!-- 14-day table -->
    <section class="mb-8">
      <h2 class="mb-4 text-lg font-semibold text-slate-200">Neste 14 dager</h2>
      {tableDays.length > 0 ? (
        <BeerSalesTable days={tableDays} />
      ) : (
        <p class="text-slate-400">Ingen data tilgjengelig</p>
      )}
    </section>

    <!-- Vinmonopolet store list -->
    <div class="mb-8">
      <VinmonopoletList stores={vinmonopolet_stores} days={tableDays} daySummary={daySummary} municipalityName={municipality.name} municipalityId={municipality.id} />
    </div>

    <!-- Sources -->
    <section class="mb-6">
      <h2 class="mb-3 text-lg font-semibold text-slate-200">Kilder</h2>
      <ul class="list-inside list-disc space-y-1 text-sm text-slate-400">
        {municipality.sources.map((source) => (
          <li>
            <a href={source.url} class="text-slate-300 underline hover:text-white" target="_blank" rel="noopener noreferrer">
              {source.title}
            </a>
          </li>
        ))}
        {vinmonopolet_stores.length > 0 && (
          <li>
            <a href="https://www.vinmonopolet.no" class="text-slate-300 underline hover:text-white" target="_blank" rel="noopener noreferrer">
              Vinmonopolet API
            </a>
          </li>
        )}
      </ul>
      {municipality.last_verified && (
        <p class="mt-2 text-sm text-slate-500">
          Sist verifisert: {formatDateLong(municipality.last_verified)}
        </p>
      )}
    </section>

    <!-- Disclaimer -->
    <section class="border-t border-slate-700 pt-4">
      <p class="text-xs text-slate-500">
        Denne siden viser siste lovlige tidspunkt for ølsalg i butikk basert på
        alkoholloven og kommunale forskrifter, samt åpningstider for Vinmonopolet
        hentet fra deres offisielle API. Faktisk butikkåpningstid kan avvike.
        Sjekk alltid med butikken ved tvil. Siden er ikke tilknyttet Vinmonopolet
        eller noen dagligvarekjede.
      </p>
    </section>
  </div>
</Base>
