---
import Base from "../layouts/Base.astro";
import { normalizeBasePath } from "../lib/dataUtils";

const basePath = normalizeBasePath(import.meta.env.BASE_URL);
---

<Base title="Siden ble ikke funnet — Alkohol-oversikt">
  <div id="not-found" class="flex flex-col items-center text-center" data-base-path={basePath}>
    <p class="mb-4 text-6xl font-bold text-slate-600">404</p>

    <div id="generic-message">
      <h1 class="mb-2 text-2xl font-semibold text-white">
        Siden ble ikke funnet
      </h1>
      <p class="mb-6 text-slate-400">
        Beklager, vi finner ikke siden du leter etter.
      </p>
    </div>

    <div id="kommune-message" class="hidden">
      <h1 class="mb-2 text-2xl font-semibold text-white">
        Denne kommunen eksisterer ikke eller er ikke implementert enda
      </h1>
      <p class="mb-6 text-slate-400">
        Vi jobber med å legge til flere kommuner.
      </p>
    </div>

    <!--
      No-JS fallback: #generic-message is visible by default, so users
      without JavaScript always see the generic 404. The kommune-specific
      message only appears when the inline script detects a /kommune/<id> path.
    -->

    <a
      href={basePath}
      class="rounded-lg border border-slate-600 bg-slate-800 px-4 py-2 text-slate-200 hover:border-slate-400 hover:text-white"
    >
      &larr; Gå til forsiden
    </a>
  </div>

  <script>
    import { stripBasePrefix, normalizePath, isKommunePath } from "../lib/pathUtils";

    const container = document.getElementById("not-found")!;
    const basePath = container.dataset.basePath ?? "/";

    const relative = normalizePath(stripBasePrefix(window.location.pathname, basePath));

    if (isKommunePath(relative)) {
      document.getElementById("generic-message")?.classList.add("hidden");
      document.getElementById("kommune-message")?.classList.remove("hidden");
    }
  </script>
</Base>
