---
interface Props {
  title: string;
  buildDate?: string;
  lastVerified?: string;
}

const { title, buildDate, lastVerified } = Astro.props;
const base = import.meta.env.BASE_URL;

function formatDateNorwegian(dateStr: string): string {
  const [year, month, day] = dateStr.split("-");
  return `${day}.${month}.${year}`;
}
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100">
    <nav class="border-b border-slate-700 bg-slate-800">
      <div class="mx-auto max-w-3xl px-4 py-4">
        <a href={base} class="text-lg font-semibold text-slate-100 hover:text-white">
          Alkohol-oversikt
        </a>
      </div>
    </nav>

    <main class="mx-auto max-w-3xl px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-slate-700 bg-slate-800">
      <div class="mx-auto max-w-3xl px-4 py-4 text-sm text-slate-400">
        <p>Alkohol-oversikt &copy; {new Date().getFullYear()}</p>
        {buildDate && (
          <p class="mt-1 text-slate-500">
            Sist oppdatert: {formatDateNorwegian(buildDate)}
            {lastVerified && <span> · Regler sist sjekket: {formatDateNorwegian(lastVerified)}</span>}
          </p>
        )}
      </div>
    </footer>
  </body>
</html>
