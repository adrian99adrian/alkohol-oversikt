---
interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100">
    <nav class="border-b border-slate-700 bg-slate-800">
      <div class="mx-auto max-w-3xl px-4 py-4">
        <a href={base} class="text-lg font-semibold text-slate-100 hover:text-white">
          Alkohol-oversikt
        </a>
      </div>
    </nav>

    <main class="mx-auto max-w-3xl px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-slate-700 bg-slate-800">
      <div class="mx-auto max-w-3xl px-4 py-4 text-sm text-slate-400">
        Alkohol-oversikt &copy; {new Date().getFullYear()}
      </div>
    </footer>
  </body>
</html>
