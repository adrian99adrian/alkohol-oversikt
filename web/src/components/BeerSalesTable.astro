---
import DayBadge from "./DayBadge.astro";
import type { DayData, VinmonopoletSummary } from "../types";

interface Props {
  days: DayData[];
}

const { days } = Astro.props;

function formatVinmonopolet(summary: VinmonopoletSummary | null): string {
  if (!summary || summary.type === "closed") return "Stengt";
  if (summary.type === "uniform") return `${summary.open}–${summary.close}`;
  // range: show earliest open to latest close for compact display
  return `${summary.min_open}–${summary.max_close}`;
}

const weekdayShort: Record<string, string> = {
  mandag: "man",
  tirsdag: "tir",
  onsdag: "ons",
  torsdag: "tor",
  fredag: "fre",
  lørdag: "lør",
  søndag: "søn",
};

function formatDateShort(dateStr: string): string {
  const [, month, day] = dateStr.split("-");
  return `${day}.${month}`;
}

const hasVinmonopolet = days.some((d) => d.vinmonopolet_summary !== null);
---

<div class="overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead>
      <tr class="border-b border-slate-700 text-slate-400">
        <th class="pb-2 pr-3 font-medium">Dato</th>
        <th class="pb-2 pr-3 font-medium">Dag</th>
        <th class="pb-2 pr-3 font-medium">Type</th>
        <th class="pb-2 pr-3 font-medium">Ølsalg</th>
        {hasVinmonopolet && <th class="pb-2 pr-3 font-medium">Vinm.</th>}
        <th class="pb-2 font-medium">Merknad</th>
      </tr>
    </thead>
    <tbody>
      {days.map((day, i) => (
        <tr class:list={[
          "border-b border-slate-700/50",
          i === 0 && "bg-slate-800/80 border-l-2 border-l-slate-400",
        ]}>
          <td class="py-2 pr-3 text-slate-300">{formatDateShort(day.date)}</td>
          <td class="py-2 pr-3 text-slate-300">{weekdayShort[day.weekday] ?? day.weekday}</td>
          <td class="py-2 pr-3">
            <DayBadge dayType={day.day_type} label={day.day_type_label} />
          </td>
          <td class="py-2 pr-3 text-slate-200">
            {day.beer_sale_allowed ? day.beer_close : "—"}
          </td>
          {hasVinmonopolet && (
            <td class="py-2 pr-3 text-slate-200">
              {formatVinmonopolet(day.vinmonopolet_summary)}
            </td>
          )}
          <td class="py-2 text-sm text-slate-400">
            {day.comment ?? ""}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
