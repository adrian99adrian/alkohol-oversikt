---
import { dayTypeColorMap } from "../lib/dayTypeColors";

interface Props {
  dayType: string;
  label: string;
}

const { dayType, label } = Astro.props;

const colors = dayTypeColorMap[dayType] ?? "bg-slate-700 text-slate-300";
---

<span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${colors}`}>
  {label}
</span>
