---
interface Props {
  dayType: string;
  label: string;
}

const { dayType, label } = Astro.props;

const colorMap: Record<string, string> = {
  weekday: "bg-green-900/50 text-green-300",
  saturday: "bg-yellow-900/50 text-yellow-300",
  pre_holiday: "bg-orange-900/50 text-orange-300",
  special_day: "bg-orange-900/50 text-orange-300",
  sunday: "bg-red-900/50 text-red-300",
  public_holiday: "bg-red-900/50 text-red-300",
};

const colors = colorMap[dayType] ?? "bg-slate-700 text-slate-300";
---

<span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${colors}`}>
  {label}
</span>
