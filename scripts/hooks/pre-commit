#!/bin/sh
#
# Pre-commit hook for alkohol-oversikt
#
# Setup (run once per machine after cloning):
#   git config core.hooksPath scripts/hooks
#
# What this does:
#   Runs automatically before every "git commit". If any check fails,
#   the commit is blocked and you'll see an error explaining what to fix.
#
# Checks:
#   1. Guard   — blocks commits that include gitignored files
#   2. Gate    — skips lint/tests if no code files are staged
#   3. Lint    — runs ruff check + format on the whole project
#   4. Tests   — runs the full pytest suite (including slow/network tests)
#   5. Fresh   — ensures generated municipality data starts from today
#

# ── 1. Gitignore guard ─────────────────────────────────────────────
# Catches files that were force-added (git add -f) despite being in
# .gitignore. Prevents accidental commits of local-only files.

STAGED=$(git diff --cached --name-only)

if [ -z "$STAGED" ]; then
    exit 0
fi

IGNORED=$(echo "$STAGED" | git check-ignore --stdin --no-index 2>/dev/null || true)

if [ -n "$IGNORED" ]; then
    echo "[pre-commit] BLOCKED: gitignored files are staged:"
    echo "$IGNORED" | sed 's/^/  /'
    echo ""
    echo "  Remove with: git reset HEAD <file>"
    exit 1
fi

echo "[pre-commit] gitignore check passed."

# ── 2. Relevant-change gate ───────────────────────────────────────
# Only run lint + tests when code-related files are staged.

RELEVANT=$(echo "$STAGED" | grep -E '\.py$|\.ya?ml$|\.sh$|\.toml$|\.txt$|\.json$|\.astro$|\.ts$|\.mjs$|\.properties$' || true)

if [ -z "$RELEVANT" ]; then
    echo "[pre-commit] no code changes staged — skipping lint and tests."
else
    echo "[pre-commit] code changes detected — running lint and tests."

    # ── 3. Lint ────────────────────────────────────────────────────
    # Only runs if Python files are being committed.
    # Checks the WHOLE project (not just staged files) because a change
    # in one file can cause lint errors in another.

    if echo "$STAGED" | grep -q '\.py$'; then

        if ! command -v ruff >/dev/null 2>&1; then
            echo "[pre-commit] WARNING: ruff not found, skipping lint checks"
        else
            echo "[pre-commit] Running ruff check..."
            if ! ruff check .; then
                echo ""
                echo "[pre-commit] BLOCKED: ruff check found issues."
                exit 1
            fi

            echo "[pre-commit] Running ruff format --check..."
            if ! ruff format --check .; then
                echo ""
                echo "[pre-commit] BLOCKED: formatting issues found."
                echo "  Fix with: ruff format ."
                exit 1
            fi
        fi
    fi

    # ── 4. Tests ───────────────────────────────────────────────────
    # Only run when Python files are staged — frontend-only changes
    # can't affect Python test results.

    if echo "$STAGED" | grep -q '\.py$'; then
        if ! command -v pytest >/dev/null 2>&1; then
            echo "[pre-commit] WARNING: pytest not found, skipping tests"
        else
            echo "[pre-commit] Running pytest..."
            if ! pytest -q tests/; then
                echo ""
                echo "[pre-commit] BLOCKED: tests failed."
                exit 1
            fi
        fi
    fi
fi

# ── 5. Generated data freshness ───────────────────────────────────
# Ensures that staged municipality JSON files start from today.
# Catches accidental commits of stale data (e.g. built with a past
# --start-date or an outdated local copy).
# Runs independently of the code-change gate.

STAGED_GENERATED=$(git diff --cached --name-only -- 'data/generated/municipalities/*.json')

if [ -n "$STAGED_GENERATED" ]; then
    TODAY=$(date +%Y-%m-%d)

    for file in $STAGED_GENERATED; do
        # Read the staged version (not the working tree version)
        FIRST_DATE=$(git show ":$file" | grep -m1 '"date":' | grep -o '[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}')

        if [ -n "$FIRST_DATE" ] && [ "$FIRST_DATE" != "$TODAY" ]; then
            echo "[pre-commit] BLOCKED: stale generated data in $file"
            echo "  First date: $FIRST_DATE (expected $TODAY)"
            echo ""
            echo "  Tests likely overwrote the generated files."
            echo "  Fix: python scripts/build_municipality.py --all"
            exit 1
        fi
    done
fi

echo "[pre-commit] All checks passed."
